# Azure AD / Microsoft Entra ID
OUTLOOK_TENANT_ID=your-tenant-id
OUTLOOK_CLIENT_ID=your-client-id
OUTLOOK_CLIENT_SECRET=your-client-secret

# Mailbox to monitor (the bot's email address)
OUTLOOK_MAILBOX=bot@yourdomain.com

# Public HTTPS URL for Graph webhook notifications
OUTLOOK_NOTIFICATION_URL=https://your-domain.com/api/webhooks/outlook-email

# Secret for webhook verification (max 128 chars)
OUTLOOK_CLIENT_STATE=your-random-secret-string

# Bot display name (optional)
OUTLOOK_BOT_NAME=Bot
